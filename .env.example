# Environment Configuration
PYTHONPATH=src

# Logging Configuration
LOG_LEVEL=INFO
LOG_FILE=logs/app.log

# Data Collection Configuration
DATA_COLLECTION_DELAY=1.0
MAX_RETRIES=3
TIMEOUT_SECONDS=30

# Source Validation
ALLOWED_DOMAINS=groww.in
SSL_VERIFY=true

# Cache Configuration
CACHE_TTL=3600
CACHE_DIR=cache

# Monitoring
MONITORING_ENABLED=true
METRICS_PORT=8000

# Groq API Configuration
GROQ_API_KEY=your_groq_api_key_here
API_BASE_URL=https://api.groq.com
